# Shield402 Lite — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
PORT=3402

# --- x402 Payment Wrapping ---
# Set to "true" to require x402 payment for /check-trade.
# When "false" or unset, the endpoint is free (useful for local dev/testing).
X402_ENABLED=false

TELEGRAM_BOT_TOKEN=<YOUR-TELEGRAM-BOT-API>

# Your Solana wallet address (base58) that receives payments.
# For devnet testing, use a devnet wallet address.
SVM_ADDRESS=<YOUR-SOL-WALLET-ADDRESS>

# Facilitator URL. Options:
#   Devnet/testnet:  https://x402.org/facilitator
#   Mainnet (CDP):   https://api.cdp.coinbase.com/platform/v2/x402
FACILITATOR_URL=https://x402.org/facilitator

# Solana network in CAIP-2 format.
#   Devnet:  solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
#   Mainnet: solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# Price per check-trade call (USD string).
X402_PRICE=$0.001

# --- API Key Auth ---
# Comma-separated list of valid API keys for /check-trade.
# When unset or empty, auth is disabled (all requests pass through).
# Authenticated requests get a higher rate limit (200/min vs 20/min).
API_KEYS=

# --- Live Market Data ---
# Jupiter API key for price impact checks.
# Get a free key at https://jup.ag
# When unset, price impact rule is skipped (static rules only).
JUPITER_API_KEY=<YOUR-JUPITER-API-KEY>

# Rugcheck API key for token risk scanning.
# Get a key at https://rugcheck.xyz
# When unset, token risk rule is skipped.
RUGCHECK_API_KEY=<YOUR-RUGCHECK-API-KEY>

# Solana RPC URL for on-chain token decimal resolution.
# Enables Jupiter price impact checks for any SPL token (not just SOL/USDC/USDT).
# The public RPC is rate-limited but fine for dev/testing.
# For production, use Helius, Alchemy, or dRPC (free tiers available).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
