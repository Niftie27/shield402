{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "rootDir": "../..",
    "outDir": "../../dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["*.ts", "../schema/**/*", "../rules/**/*", "../data/**/*", "../types/**/*", "../config/**/*", "../logging/**/*"]
}
