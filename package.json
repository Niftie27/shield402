{
  "name": "shield402-lite",
  "version": "0.1.0",
  "description": "Pre-trade safety API for Solana. Checks a proposed trade and returns a risk label, reason, and recommendation.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "mcp": "tsx src/mcp/server.ts",
    "test": "tsc --noEmit && tsc --noEmit -p src/mcp/tsconfig.json && vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "solana",
    "x402",
    "mev-protection",
    "trade-safety"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@solana/kit": "^5.5.1",
    "@x402/core": "^2.6.0",
    "@x402/express": "^2.6.0",
    "@x402/svm": "^2.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "grammy": "^1.41.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
